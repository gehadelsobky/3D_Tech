# ============================================================
#  3D Tech — Environment Variables
#  Copy this file:  cp .env.example .env
#  Then edit with your production values
# ============================================================

# Server
PORT=3001
NODE_ENV=production

# Security — CHANGE THIS! Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS — comma-separated allowed origins (leave empty to allow all)
# Example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=

# Email (SMTP) — for form submission notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=
